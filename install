#!/bin/zsh

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_FILE="$ROOT_DIR/APIKeyManager.xcodeproj"
PROJECT_SPEC="$ROOT_DIR/project.yml"
DERIVED_DATA_DIR="$ROOT_DIR/.build/DerivedData"
BUILD_APP_PATH="$DERIVED_DATA_DIR/Build/Products/Debug/Apivault.app"
INSTALL_APP_PATH="/Applications/Apivault.app"
LEGACY_APP_PATH="/Applications/APIKeyManager.app"

log() {
  printf '\n==> %s\n' "$1"
}

fail() {
  printf '\nError: %s\n' "$1" >&2
  exit 1
}

command -v xcodebuild >/dev/null 2>&1 || fail "xcodebuild is required. Install Xcode first."

if [[ ! -d "$PROJECT_FILE" || "$PROJECT_SPEC" -nt "$PROJECT_FILE" ]]; then
  command -v xcodegen >/dev/null 2>&1 || fail "xcodegen is required to generate the Xcode project. Install it with 'brew install xcodegen'."
  log "Generating Xcode project"
  (
    cd "$ROOT_DIR"
    xcodegen generate
  )
fi

log "Building Apivault"
xcodebuild \
  -project "$PROJECT_FILE" \
  -scheme APIKeyManager \
  -configuration Debug \
  -destination "platform=macOS" \
  -derivedDataPath "$DERIVED_DATA_DIR" \
  build

[[ -d "$BUILD_APP_PATH" ]] || fail "Built app was not found at $BUILD_APP_PATH"

log "Installing into /Applications"
if [[ -w "/Applications" ]]; then
  rm -rf "$LEGACY_APP_PATH"
  rm -rf "$INSTALL_APP_PATH"
  ditto "$BUILD_APP_PATH" "$INSTALL_APP_PATH"
else
  sudo rm -rf "$LEGACY_APP_PATH"
  sudo rm -rf "$INSTALL_APP_PATH"
  sudo ditto "$BUILD_APP_PATH" "$INSTALL_APP_PATH"
fi

log "Launching Apivault"
open "$INSTALL_APP_PATH"

cat <<'EOF'

Installed: /Applications/Apivault.app

Manual Safari step:
1. Open Safari.
2. Go to Safari > Settings > Extensions.
3. Enable "Apivault Extension".
4. If it does not appear, quit and reopen Safari once.

EOF
