{
  "manifest_version": 3,
  "name": "Apivault",
  "description": "Save API keys from Safari into your local dashboard.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:38173/*"
  ],
  "action": {
    "default_title": "Apivault",
    "default_popup": "popup.html"
  }
}
